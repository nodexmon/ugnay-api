// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS

enum Role {
  CUSTOMER
  WORKER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum WorkerStatus {
  PENDING // Submitted application, awaiting admin review
  VERIFIED // Admin approved — can receive bookings
  REJECTED // Admin rejected — may reapply once
  SUSPENDED // Suspended by admin due to strikes or complaints
}

enum BookingStatus {
  PENDING // Awaiting worker response (30-min window)
  ACCEPTED // Worker accepted — phone number revealed to customer
  REJECTED // Worker rejects - customer books another
  IN_PROGRESS // Worker marked arrival
  COMPLETED // Worker marked job complete
  CANCELLED // Cancelled by customer (pre-accept) or worker (post-accept = strike)
  EXPIRED // Worker did not respond within 30 minutes
  NO_SHOW // Admin-confirmed worker no-show
}

enum TimeWindow {
  MORNING // 06:00 – 12:00
  AFTERNOON // 12:00 – 18:00
  EVENING // 18:00 – 21:00
}

enum BookingType {
  IMMEDIATE // Same-day, ASAP
  SCHEDULED // Up to 7 days in advance
}

enum StrikeReason {
  POST_ACCEPT_CANCELLATION // Worker cancelled after accepting
  NO_SHOW // Confirmed no-show by admin
  CUSTOMER_COMPLAINT // Admin-validated complaint
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CredentialType {
  LICENSE
  CERTIFICATION
  TRAINING
}

enum Platform {
  IOS
  ANDROID
}

enum CancellationActor {
  CUSTOMER
  WORKER
  SYSTEM // Auto-expiry or admin action
}

// =============================================================================
// CORE USER
// =============================================================================

model User {
  id        String     @id @default(uuid()) @db.Uuid
  phone     String     @unique
  role      Role
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  workerProfile   WorkerProfile?
  customerProfile CustomerProfile?
  pushTokens      PushToken[]
  otpRequests     OtpRequest[]
  refreshTokens   RefreshToken[]

  @@map("users")
}

// =============================================================================
// OTP / AUTH
// =============================================================================

model OtpRequest {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  phone     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phone, verified, expiresAt])
  @@map("otp_requests")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// =============================================================================
// CUSTOMER
// =============================================================================

model CustomerProfile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  firstName String
  lastName  String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
  reviews  Review[]

  @@map("customer_profiles")
}

// =============================================================================
// WORKER
// =============================================================================

model WorkerProfile {
  id                 String       @id @default(uuid()) @db.Uuid
  userId             String       @unique @db.Uuid
  firstName          String
  lastName           String
  bio                String?      @db.VarChar(500)
  avatarUrl          String?
  baseRate           Decimal      @db.Decimal(10, 2)
  status             WorkerStatus @default(PENDING)
  isOnline           Boolean      @default(false)
  homeBarangayId     String       @db.Uuid
  strikeCount        Int          @default(0)
  totalJobsCompleted Int          @default(0)
  averageRating      Decimal      @default(0) @db.Decimal(3, 2)
  totalReviews       Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Relations
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeBarangay     Barangay            @relation("HomeBarangay", fields: [homeBarangayId], references: [id])
  categories       WorkerCategory[]
  serviceAreas     WorkerServiceArea[]
  verificationDocs VerificationDoc[]
  credentials      WorkerCredential[]
  bookings         Booking[]
  reviews          Review[]
  strikes          Strike[]

  @@index([status, isOnline])
  @@index([homeBarangayId])
  @@index([averageRating])
  @@map("worker_profiles")
}

// Up to 3 categories per worker; optional rate override per category
model WorkerCategory {
  id           String   @id @default(uuid()) @db.Uuid
  workerId     String   @db.Uuid
  categoryId   String   @db.Uuid
  rateOverride Decimal? @db.Decimal(10, 2)
  createdAt    DateTime @default(now())

  worker   WorkerProfile   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  category ServiceCategory @relation(fields: [categoryId], references: [id])

  @@unique([workerId, categoryId])
  @@index([workerId])
  @@map("worker_categories")
}

// Barangays a worker is willing to serve (max 5)
model WorkerServiceArea {
  id         String   @id @default(uuid()) @db.Uuid
  workerId   String   @db.Uuid
  barangayId String   @db.Uuid
  createdAt  DateTime @default(now())

  worker   WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  barangay Barangay      @relation(fields: [barangayId], references: [id])

  @@unique([workerId, barangayId])
  @@index([workerId])
  @@map("worker_service_areas")
}

// =============================================================================
// VERIFICATION
// =============================================================================

model VerificationDoc {
  id              String             @id @default(uuid()) @db.Uuid
  workerId        String             @db.Uuid
  idPhotoUrl      String
  selfieUrl       String
  status          VerificationStatus @default(PENDING)
  rejectionReason String?
  reviewedBy      String?            @db.Uuid // Admin user ID
  reviewedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  worker WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([workerId])
  @@map("verification_docs")
}

model WorkerCredential {
  id              String             @id @default(uuid()) @db.Uuid
  workerId        String             @db.Uuid
  type            CredentialType
  fileUrl         String
  status          VerificationStatus @default(PENDING)
  rejectionReason String?
  reviewedBy      String?            @db.Uuid // Admin user ID
  reviewedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  worker WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([workerId])
  @@map("worker_credentials")
}

// =============================================================================
// GEOGRAPHY
// =============================================================================

model Barangay {
  id          String   @id @default(uuid()) @db.Uuid
  psgcCode    String?  @unique
  name        String   @unique
  centroidLat Decimal? @db.Decimal(10, 7)
  centroidLng Decimal? @db.Decimal(10, 7)
  isActive    Boolean  @default(true)

  workerHomes WorkerProfile[]     @relation("HomeBarangay")
  workerAreas WorkerServiceArea[]
  bookings    Booking[]

  @@map("barangays")
}

// =============================================================================
// SERVICE CATEGORIES
// =============================================================================

model ServiceCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  slug      String   @unique
  iconUrl   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workers  WorkerCategory[]
  bookings Booking[]

  @@map("service_categories")
}

// =============================================================================
// BOOKINGS
// =============================================================================

model Booking {
  id              String        @id @default(uuid()) @db.Uuid
  customerId      String        @db.Uuid
  workerId        String        @db.Uuid
  categoryId      String        @db.Uuid
  barangayId      String        @db.Uuid
  status          BookingStatus @default(PENDING)
  bookingType     BookingType
  scheduledDate   DateTime
  timeWindow      TimeWindow
  locationLat     Decimal       @db.Decimal(10, 7)
  locationLng     Decimal       @db.Decimal(10, 7)
  locationAddress String?       @db.VarChar(300)
  notes           String?       @db.VarChar(500)
  agreedRate      Decimal?      @db.Decimal(10, 2) // Confirmed rate at booking time

  // Timestamps for lifecycle tracking
  acceptedAt  DateTime?
  rejectedAt  DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  expiresAt   DateTime // PENDING expiry: createdAt + 30 mins

  cancellationActor  CancellationActor?
  cancellationReason String?            @db.VarChar(300)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customer     CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Restrict)
  worker       WorkerProfile   @relation(fields: [workerId], references: [id], onDelete: Restrict)
  category     ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  barangay     Barangay        @relation(fields: [barangayId], references: [id], onDelete: Restrict)
  review       Review?
  noShowReport NoShowReport?
  strikes      Strike[]

  @@index([customerId, status])
  @@index([workerId, status])
  @@index([status, expiresAt]) // For expiry cron job
  @@index([scheduledDate])
  @@map("bookings")
}

// =============================================================================
// REVIEWS
// =============================================================================

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  bookingId  String   @unique @db.Uuid // 1:1 with bookings
  customerId String   @db.Uuid
  workerId   String   @db.Uuid
  rating     Int // 1–5
  comment    String?  @db.VarChar(500)
  createdAt  DateTime @default(now())

  booking  Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  worker   WorkerProfile   @relation(fields: [workerId], references: [id], onDelete: Restrict)
  customer CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([workerId])
  @@index([customerId])
  @@map("reviews")
}

// =============================================================================
// NO-SHOW REPORTS
// =============================================================================

model NoShowReport {
  id          String    @id @default(uuid()) @db.Uuid
  bookingId   String    @unique @db.Uuid
  reportedBy  String    @db.Uuid // Customer user ID
  description String?   @db.VarChar(500)
  resolvedBy  String?   @db.Uuid // Admin user ID
  resolvedAt  DateTime?
  confirmed   Boolean? // Admin verdict: true = strike issued, false = dismissed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([confirmed])
  @@map("no_show_reports")
}

// =============================================================================
// STRIKES
// =============================================================================

model Strike {
  id        String       @id @default(uuid()) @db.Uuid
  workerId  String       @db.Uuid
  bookingId String?      @db.Uuid
  reason    StrikeReason
  issuedBy  String // Admin user ID or 'SYSTEM'
  notes     String?      @db.VarChar(300)
  createdAt DateTime     @default(now())

  worker  WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  booking Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@unique([bookingId])
  @@index([workerId])
  @@map("strikes")
}

// =============================================================================
// PUSH NOTIFICATIONS
// =============================================================================

model PushToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  platform  Platform
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}
