# Application
NODE_ENV="development"
PORT=3000
CORS_ORIGIN=""  # Leave blank to disable CORS (mobile-only); set to origin URL for web clients

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ugnay"

# JWT
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# File uploads
UPLOAD_DIR="uploads"

# Seed
ADMIN_PHONE="+639171234567"  # Initial admin account created by pnpm db:seed; leave unset to skip

# TextBee SMS gateway (https://textbee.dev)
TEXTBEE_API_URL="https://api.textbee.dev/api/v1"
SMS_API_KEY="your-textbee-api-key"
DEVICE_ID="your-textbee-device-id"

# PSGC (Philippine Standard Geographic Code)
PSGC_API_URL="https://psgc.gitlab.io/api"
PSGC_CALAPAN_CODE="175205000"  # City of Calapan; change to target a different municipality
