# Application
NODE_ENV="development"
PORT=3000
CORS_ORIGIN=""  # Leave blank to disable CORS (mobile-only); set to origin URL for web clients

# Number of trusted reverse proxies in front of the app. This decides how req.ip
# is derived from X-Forwarded-For, which the OTP/SMS rate limiter keys on.
# Set it too high and clients can spoof X-Forwarded-For to bypass throttling
# (SMS bombing). Set it too low behind a real proxy and every client collapses
# into one bucket. Match your topology:
#   1        -> exactly one reverse proxy (nginx / single ALB)   [default]
#   2        -> CDN in front of a load balancer (e.g. Cloudflare + LB)
#   false    -> no proxy; app is exposed directly to clients
#   loopback -> or a comma-separated IP/subnet list of trusted proxies
TRUST_PROXY="1"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ugnay"

# JWT
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# File uploads
UPLOAD_DIR="uploads"        # Logical prefix in stored file URLs and the /uploads route
# Physical directory where files are written. Defaults to <cwd>/UPLOAD_DIR.
# In production, point this at a restricted volume OUTSIDE the deploy directory
# (verification IDs/selfies are PII). May be absolute or cwd-relative.
UPLOAD_ROOT="/var/lib/ugnay/uploads"

# Seed
ADMIN_PHONE="+639171234567"  # Initial admin account created by pnpm db:seed; leave unset to skip

# TextBee SMS gateway (https://textbee.dev)
TEXTBEE_API_URL="https://api.textbee.dev/api/v1"
SMS_API_KEY="your-textbee-api-key"
DEVICE_ID="your-textbee-device-id"

# PSGC (Philippine Standard Geographic Code)
PSGC_API_URL="https://psgc.gitlab.io/api"
PSGC_CALAPAN_CODE="175205000"  # City of Calapan; change to target a different municipality
